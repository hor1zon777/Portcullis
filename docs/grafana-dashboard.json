{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Challenge 发放速率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(captcha_challenge_issued_total[5m])",
          "legendFormat": "{{site_key}}"
        }
      ]
    },
    {
      "title": "Verify 成功/失败速率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(captcha_verify_success_total[5m])",
          "legendFormat": "成功 {{site_key}}"
        },
        {
          "expr": "rate(captcha_verify_fail_total[5m])",
          "legendFormat": "失败 {{site_key}}"
        }
      ]
    },
    {
      "title": "Verify 延迟 (p50/p95/p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(captcha_verify_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(captcha_verify_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(captcha_verify_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "SiteVerify 成功/失败速率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(captcha_siteverify_success_total[5m])",
          "legendFormat": "成功"
        },
        {
          "expr": "rate(captcha_siteverify_fail_total[5m])",
          "legendFormat": "失败"
        }
      ]
    },
    {
      "title": "Store 条目数",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "captcha_store_challenges_used",
          "legendFormat": "challenges"
        },
        {
          "expr": "captcha_store_tokens_used",
          "legendFormat": "tokens"
        }
      ]
    },
    {
      "title": "Verify 失败率",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "rate(captcha_verify_fail_total[5m]) / (rate(captcha_verify_success_total[5m]) + rate(captcha_verify_fail_total[5m]))",
          "legendFormat": "失败率"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "red", "value": 0.7 }
            ]
          },
          "unit": "percentunit",
          "max": 1
        }
      }
    },
    {
      "title": "Challenge/Verify 比例",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "targets": [
        {
          "expr": "rate(captcha_challenge_issued_total[5m]) / (rate(captcha_verify_success_total[5m]) + rate(captcha_verify_fail_total[5m]) + 0.001)",
          "legendFormat": "比例"
        }
      ],
      "description": ">5 可能表示自动化脚本在刷 challenge 但不提交 verify"
    }
  ],
  "schemaVersion": 39,
  "tags": ["captcha", "pow"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "PoW CAPTCHA Dashboard",
  "uid": "pow-captcha-v1"
}
