# PoW CAPTCHA 环境配置
# 复制此文件为 .env 并修改

# ──── 服务端 ────
CAPTCHA_SECRET=CHANGE_ME_USE_captcha-server_gen-secret
CAPTCHA_BIND=0.0.0.0:8787
CAPTCHA_CHALLENGE_TTL_SECS=120
CAPTCHA_TOKEN_TTL_SECS=300

# ──── 数据库 ────
CAPTCHA_DB_PATH=data/captcha.db

# ──── 管理面板 ────
CAPTCHA_ADMIN_TOKEN=CHANGE_ME_USE_captcha-server_gen-secret

# ──── 初始站点（JSON，仅首次启动 seed 到 DB，后续通过管理面板管理）────
CAPTCHA_SITES={"pk_example":{"secret_key":"sk_example_change_me_min16","diff":18,"origins":["https://example.com"]}}
