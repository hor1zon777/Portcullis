# PoW CAPTCHA 环境配置
# 复制此文件为 .env 并修改
#
# 生成密钥：openssl rand -hex 32

# ──── 服务端 ────
# HMAC 签名主密钥（>= 32 字节）
CAPTCHA_SECRET=替换为 openssl rand -hex 32 的输出
CAPTCHA_BIND=0.0.0.0:8787
CAPTCHA_CHALLENGE_TTL_SECS=120
CAPTCHA_TOKEN_TTL_SECS=300

# ──── 数据库 ────
CAPTCHA_DB_PATH=data/captcha.db

# ──── 管理面板 ────
# 访问地址：http://host:PORT/admin?token=此值
CAPTCHA_ADMIN_TOKEN=替换为 openssl rand -hex 32 的输出

# ──── Docker ────
# Nginx 网关对外映射端口
NGINX_PORT=80

# ──── 初始站点（可选，JSON，仅首次 seed 到 DB，后续通过管理面板管理）────
# 注意：值必须用单引号包裹，否则 JSON 中的双引号会导致解析错误
# 也可以不设此项，启动后在管理面板手动创建站点
# CAPTCHA_SITES='{"pk_example":{"secret_key":"sk_example_change_me_min16","diff":18,"origins":["https://example.com"]}}'
